.modal h2{font-family:'Orbitron',monospace;font-size:.88rem;color:var(--accent);letter-spacing:.1em;margin-bottom:1.2rem;}
.modal label{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--dim);display:block;margin-bottom:.25rem;margin-top:.7rem;letter-spacing:.08em;text-transform:uppercase;}
.modal input{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);font-family:'Exo 2',sans-serif;font-size:.9rem;padding:.55rem .8rem;outline:none;margin-bottom:.5rem;}
.modal input:focus{border-color:var(--accent);}
.modal-btns{display:flex;gap:.6rem;justify-content:flex-end;margin-top:1rem;}

/* ── POL DOC ── */
.pol-preview{background:var(--surface2);border:1px solid var(--border);padding:.9rem;font-family:'Share Tech Mono',monospace;font-size:.7rem;line-height:1.8;color:var(--dim);max-height:200px;overflow-y:auto;margin-top:.6rem;}

/* ── EMPTY STATE ── */
.empty{text-align:center;padding:3rem 1rem;font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--dim);}
.empty .big{font-size:2.5rem;margin-bottom:.5rem;}

/* ── ANNOUNCE BANNER ── */
.announce{position:fixed;top:70px;left:50%;transform:translateX(-50%);z-index:200;background:var(--accent);color:var(--bg);font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;padding:.7rem 2rem;letter-spacing:.1em;display:none;text-align:center;box-shadow:0 4px 30px rgba(0,200,240,.5);}
.announce.show{display:block;animation:slidedown .4s ease;}
@keyframes slidedown{from{top:50px;opacity:0}to{top:70px;opacity:1}}

