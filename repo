.lb-panel{display:flex;flex-direction:column;border-right:1px solid var(--border);overflow:hidden;}
.lb-header{padding:.7rem 1rem;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.lb-header h2{font-family:'Orbitron',monospace;font-size:.82rem;color:var(--gold);letter-spacing:.12em;}
.lb-live{display:flex;align-items:center;gap:.4rem;font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--green);}
.lb-live .dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 1.4s infinite;}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,229,160,.6)}50%{opacity:.7;box-shadow:0 0 0 5px rgba(0,229,160,0)}}
.lb-scroll{flex:1;overflow-y:auto;padding:.5rem;}
.lb-scroll::-webkit-scrollbar{width:4px;}
.lb-scroll::-webkit-scrollbar-track{background:var(--surface);}
.lb-scroll::-webkit-scrollbar-thumb{background:var(--border);}

/* ── LB ROWS ── */
.lb-row{display:grid;grid-template-columns:42px 1fr auto;align-items:center;gap:.6rem;padding:.55rem .8rem;margin-bottom:3px;background:var(--surface2);border:1px solid var(--border);transition:all .3s;position:relative;overflow:hidden;}
.lb-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--border);}
.lb-row.r1::before{background:var(--gold);}
.lb-row.r2::before{background:#c0c0c0;}
.lb-row.r3::before{background:#cd7f32;}
.lb-row.new-entry{animation:newrow .6s ease;}
@keyframes newrow{from{transform:translateX(-20px);opacity:0}to{transform:translateX(0);opacity:1}}
.lb-rank{font-family:'Orbitron',monospace;font-size:.85rem;font-weight:900;text-align:center;}
.r1 .lb-rank{color:var(--gold);}
.r2 .lb-rank{color:#c0c0c0;}
.r3 .lb-rank{color:#cd7f32;}
.lb-info{min-width:0;}
.lb-name{font-weight:700;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lb-class{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--dim);}
.lb-games{display:flex;gap:3px;margin-top:2px;}
.lb-badge{font-size:.58rem;padding:1px 4px;border:1px solid var(--border);font-family:'Share Tech Mono',monospace;color:var(--dim);white-space:nowrap;}
.lb-badge.has{border-color:var(--green);color:var(--green);}
.lb-score-wrap{text-align:right;}
.lb-total{font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:900;color:var(--yellow);}
.lb-sub{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--dim);}

/* ── PROGRESS BAR ── */
.lb-prog{height:3px;background:var(--border);margin-top:3px;overflow:hidden;}
.lb-prog-bar{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));transition:width .6s ease;}

/* ── RIGHT PANEL ── */
.right-panel{display:flex;flex-direction:column;overflow:hidden;}

/* ── STATS STRIP ── */
.stats-strip{padding:.7rem .9rem;background:var(--surface);border-bottom:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr;gap:.5rem;flex-shrink:0;}
.stat-box{background:var(--surface2);border:1px solid var(--border);padding:.5rem .7rem;text-align:center;}
.stat-v{font-family:'Orbitron',monospace;font-size:1.3rem;font-weight:900;color:var(--accent);line-height:1;}
.stat-l{font-family:'Share Tech Mono',monospace;font-size:.58rem;color:var(--dim);margin-top:.2rem;letter-spacing:.06em;}

/* ── GAME BREAKDOWN ── */
.game-breakdown{padding:.7rem .9rem;border-bottom:1px solid var(--border);flex-shrink:0;}
.section-title{font-family:'Orbitron',monospace;font-size:.65rem;color:var(--accent2);letter-spacing:.1em;margin-bottom:.5rem;}
.game-row{display:flex;align-items:center;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid rgba(26,58,92,.3);font-size:.8rem;}
.game-row:last-child{border-bottom:none;}
.game-row .gn{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--dim);}
.game-row .gc{font-family:'Orbitron',monospace;font-size:.8rem;color:var(--accent);font-weight:700;}

/* ── PYTHON PROGRESS ── */
.py-progress{padding:.7rem .9rem;border-bottom:1px solid var(--border);flex-shrink:0;}
.py-topic{display:flex;align-items:center;gap:.5rem;margin-bottom:.35rem;}
.py-topic .pt-name{font-family:'Share Tech Mono',monospace;font-size:.65rem;color:var(--dim);flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.py-topic .pt-bar{flex:2;height:6px;background:var(--surface3);border-radius:3px;overflow:hidden;}
.py-topic .pt-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--green));border-radius:3px;transition:width .5s;}
.py-topic .pt-count{font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--dim);min-width:28px;text-align:right;}

/* ── CONTROL PANEL ── */
.ctrl-panel{padding:.7rem .9rem;flex:1;overflow-y:auto;}
.ctrl-row{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.6rem;}

/* ── GS STATUS ── */
.gs-bar{padding:.5rem .9rem;background:var(--surface2);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:.5rem;flex-shrink:0;font-family:'Share Tech Mono',monospace;font-size:.65rem;}
.gs-indicator{display:flex;align-items:center;gap:.4rem;}
.gs-dot{width:7px;height:7px;border-radius:50%;background:var(--dim);}
.gs-dot.on{background:var(--green);box-shadow:0 0 5px var(--green);}
.gs-dot.err{background:var(--red);}

/* ── BOTTOMBAR ── */
.bottombar{position:relative;z-index:10;background:var(--surface);border-top:1px solid var(--border);padding:.4rem 1.2rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.footer-txt{font-family:'Share Tech Mono',monospace;font-size:.62rem;color:var(--dim);letter-spacing:.08em;}

/* ── MODAL ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100;align-items:center;justify-content:center;}
.modal-bg.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);padding:1.8rem;max-width:520px;width:90%;position:relative;}
