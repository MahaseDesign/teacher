<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>CBA CS — Teacher Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
<style>

:root {
  --bg:#07101f; --surface:#0f1e33; --surface2:#172845;
  --border:#1a3a5c; --accent:#00c8f0; --accent2:#ff7b2c;
  --green:#00e5a0; --red:#ff3d5a; --yellow:#ffd426;
  --text:#d6f0ff; --dim:#4a7a9b; --gold:#ffd700;
  --p1:#00c8f0; --p2:#ff7b2c;
}
/* ── LIGHT MODE ── */
body.light{
  --bg:#f0f4f8; --surface:#ffffff; --surface2:#e4ecf3;
  --border:#b0c8de; --accent:#0077a8; --accent2:#c85000;
  --green:#007a52; --red:#c01535; --yellow:#8a6800;
  --text:#0a1825; --dim:#3d6278; --gold:#a07800;
  --p1:#0077a8; --p2:#c85000;
}
body.light::before{background-image:linear-gradient(rgba(0,100,160,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,100,160,.04) 1px,transparent 1px);}
body.light::after{background:radial-gradient(ellipse at 15% 40%,rgba(0,100,160,.05) 0%,transparent 55%),radial-gradient(ellipse at 85% 15%,rgba(200,80,0,.04) 0%,transparent 50%);}
body.light .g-header{background:linear-gradient(135deg,rgba(0,119,168,.08) 0%,rgba(240,244,248,.98) 100%);}
body.light .g-logo{text-shadow:none;}
body.light .reg-top h1{text-shadow:none;}
body.light .sec-title{text-shadow:none;}
body.light .qz-big{text-shadow:none;}
body.light .nc-score{text-shadow:none;}
body.light .w-cell{background:#fff;}
body.light .w-cell.correct{background:#c8f0dc;border-color:var(--green);color:var(--green);}
body.light .w-cell.present{background:#fff0b0;border-color:var(--yellow);color:var(--yellow);}
body.light .w-cell.absent{background:#dde4ec;border-color:#aab8c8;color:#8899aa;}
body.light .kb-key{background:#e4ecf3;}
body.light .kb-key.correct{background:#c8f0dc;border-color:var(--green);color:var(--green);}
body.light .kb-key.present{background:#fff0b0;border-color:var(--yellow);color:var(--yellow);}
body.light .kb-key.absent{background:#dde4ec;border-color:#aab8c8;color:#8899aa;}
body.light .nc-tbar{opacity:.85;}
body{transition:background .25s,color .25s;}
.theme-toggle{font-family:'Share Tech Mono',monospace;font-size:.72rem;background:transparent;border:1px solid var(--border);color:var(--dim);cursor:pointer;padding:.3rem .75rem;white-space:nowrap;transition:all .18s;letter-spacing:.05em;}
.theme-toggle:hover{border-color:var(--accent);color:var(--accent);}
/* ── COLOUR FILTERS ── */
.filter-overlay{position:fixed;inset:0;pointer-events:none;z-index:9999;opacity:0;transition:opacity .3s;}
body.filter-blue  .filter-overlay{background:rgba(173,216,230,0.25);opacity:1;}
body.filter-green .filter-overlay{background:rgba(144,238,144,0.22);opacity:1;}
.filter-btn{font-family:'Share Tech Mono',monospace;font-size:.68rem;padding:.28rem .65rem;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--dim);transition:all .18s;white-space:nowrap;}
.filter-btn:hover{border-color:var(--accent);color:var(--accent);}
.filter-btn.active-blue{background:rgba(100,149,237,.25);border-color:#6495ED;color:#6495ED;}
.filter-btn.active-green{background:rgba(60,179,113,.2);border-color:#3CB371;color:#3CB371;}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;}
body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,200,240,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,240,.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0;animation:gridscroll 25s linear infinite;}
@keyframes gridscroll{to{background-position:48px 48px;}}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 15% 40%,rgba(0,200,240,.05) 0%,transparent 55%),radial-gradient(ellipse at 85% 15%,rgba(255,123,44,.04) 0%,transparent 50%);pointer-events:none;z-index:0;}

/* ── SCREENS ── */
.screen{display:none;position:relative;z-index:10;min-height:100vh;flex-direction:column;}
.screen.active{display:flex;}

/* ── GLOBAL HEADER ── */
.g-header{background:linear-gradient(135deg,rgba(0,200,240,.08) 0%,rgba(7,16,31,.95) 100%);border-bottom:1px solid var(--border);padding:.7rem 1.4rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.g-logo{font-family:'Orbitron',monospace;font-size:.85rem;font-weight:900;color:var(--accent);letter-spacing:.12em;text-shadow:0 0 18px rgba(0,200,240,.5);}
.g-logo em{color:var(--accent2);font-style:normal;}
.g-meta{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--dim);text-align:right;line-height:1.5;}

/* ── BUTTONS ── */
.btn{font-family:'Orbitron',monospace;font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.65rem 1.5rem;cursor:pointer;transition:all .2s;border:1px solid;background:transparent;}
.btn-pri{background:var(--accent);border-color:var(--accent);color:var(--bg);box-shadow:0 0 20px rgba(0,200,240,.3);}
.btn-pri:hover{box-shadow:0 0 35px rgba(0,200,240,.55);transform:translateY(-1px);}
.btn-sec{border-color:var(--border);color:var(--dim);}
.btn-sec:hover{border-color:var(--accent);color:var(--accent);}
.btn-org{border-color:var(--accent2);color:var(--accent2);}
.btn-org:hover{background:var(--accent2);color:#fff;}
.btn-grn{border-color:var(--green);color:var(--green);}
.btn-grn:hover{background:var(--green);color:var(--bg);}
.btn-blk{border-color:var(--border);color:var(--dim);font-size:.62rem;}
.btn-blk:hover{border-color:var(--red);color:var(--red);}
.btn-w100{width:100%;padding:.85rem;}

/* ── INPUTS ── */
input[type=text]{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);font-family:'Exo 2',sans-serif;font-size:1rem;font-weight:600;padding:.65rem .9rem;outline:none;transition:border-color .2s;}
input[type=text]:focus{border-color:var(--accent);box-shadow:0 0 10px rgba(0,200,240,.2);}
label{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--dim);display:block;margin-bottom:.3rem;letter-spacing:.08em;text-transform:uppercase;}

/* ── MSG BAR ── */
.msg{font-family:'Share Tech Mono',monospace;font-size:.82rem;padding:.65rem .9rem;border:1px solid var(--border);min-height:2.4rem;margin:.5rem 0;}
.msg.ok{border-color:var(--green);color:var(--green);background:rgba(0,229,160,.05);}
.msg.err{border-color:var(--red);color:var(--red);background:rgba(255,61,90,.05);}
.msg.info{border-color:var(--accent);color:var(--accent);background:rgba(0,200,240,.05);}

/* ── SECTION TITLE ── */
.sec-title{font-family:'Orbitron',monospace;font-size:1.5rem;font-weight:900;color:var(--accent);text-shadow:0 0 25px rgba(0,200,240,.4);margin-bottom:.25rem;}
.sec-sub{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--dim);letter-spacing:.08em;}

/* ══════════════════════════════════════════════════
   REGISTER / HOME
══════════════════════════════════════════════════ */
#register{align-items:center;justify-content:center;padding:1.5rem 1rem;}
.reg-wrap{max-width:860px;width:100%;}
.reg-top{text-align:center;margin-bottom:2rem;}
.reg-top h1{font-family:'Orbitron',monospace;font-size:clamp(1.5rem,4vw,2.6rem);font-weight:900;color:var(--accent);text-shadow:0 0 40px rgba(0,200,240,.5),0 0 80px rgba(0,200,240,.2);letter-spacing:.12em;margin-bottom:.4rem;}
.reg-top p{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--dim);letter-spacing:.1em;}
.reg-card{background:var(--surface);border:1px solid var(--border);padding:1.8rem 1.6rem;margin-bottom:1.5rem;position:relative;}
.reg-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.reg-card h2{font-family:'Orbitron',monospace;font-size:.82rem;color:var(--accent2);letter-spacing:.1em;margin-bottom:1.2rem;}
.reg-fields{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
@media(max-width:480px){.reg-fields{grid-template-columns:1fr;}}
.reg-fields .field{display:flex;flex-direction:column;gap:.3rem;}
.info-note{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:#f9a03f;background:rgba(247,127,0,.06);border:1px dashed rgba(247,127,0,.3);padding:.7rem .9rem;margin:.9rem 0 1.2rem;line-height:1.6;}
.games-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.8rem;margin-bottom:1.5rem;}
.game-tile{background:var(--surface);border:1px solid var(--border);padding:1.2rem .9rem;text-align:center;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;}
.game-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent);transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.game-tile:hover::before{transform:scaleX(1);}
.game-tile:hover{border-color:var(--accent);background:var(--surface2);transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,200,240,.12);}
.game-tile .icon{font-size:2rem;margin-bottom:.5rem;display:block;}
.game-tile .name{font-family:'Orbitron',monospace;font-size:.72rem;font-weight:700;color:var(--accent);margin-bottom:.3rem;}
.game-tile .desc{font-size:.75rem;color:var(--dim);line-height:1.4;}
.gs-status{display:flex;align-items:center;gap:.5rem;font-family:'Share Tech Mono',monospace;font-size:.72rem;margin-top:1rem;}
.gs-dot{width:8px;height:8px;border-radius:50%;background:var(--dim);}
.gs-dot.on{background:var(--green);box-shadow:0 0 6px var(--green);}
.gs-dot.err{background:var(--red);}
.gs-setup{background:var(--surface2);border:1px solid var(--border);padding:1rem 1.2rem;margin-top:.8rem;}
.gs-setup p{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--dim);margin-bottom:.5rem;line-height:1.6;}
.gs-setup input{font-size:.82rem;}

/* ══════════════════════════════════════════════════
   NAV / GAME SELECTOR
══════════════════════════════════════════════════ */
.game-nav{background:var(--surface);border-bottom:1px solid var(--border);display:flex;gap:0;overflow-x:auto;flex-shrink:0;}
.nav-tab{font-family:'Orbitron',monospace;font-size:.62rem;font-weight:700;letter-spacing:.08em;padding:.65rem 1rem;background:transparent;border:none;border-right:1px solid var(--border);color:var(--dim);cursor:pointer;white-space:nowrap;transition:all .18s;text-transform:uppercase;}
.nav-tab:hover{color:var(--accent);background:rgba(0,200,240,.04);}
.nav-tab.active{color:var(--accent);background:rgba(0,200,240,.08);border-bottom:2px solid var(--accent);}
.player-badge{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--accent2);padding:.65rem 1rem;margin-left:auto;white-space:nowrap;border-left:1px solid var(--border);}

/* ══════════════════════════════════════════════════
   GAME CONTAINER
══════════════════════════════════════════════════ */
#game-area{flex:1;overflow-y:auto;}
.game-panel{display:none;padding:1.5rem;max-width:760px;margin:0 auto;}
.game-panel.active{display:block;}

/* ══════════════════════════════════════════════════
   WORDLE
══════════════════════════════════════════════════ */
#wp-category{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--accent2);margin-bottom:.3rem;letter-spacing:.08em;}
#wp-hint{font-family:'Share Tech Mono',monospace;font-size:.92rem;color:var(--text);padding:.7rem 1rem;border:1px dashed var(--border);margin-bottom:1rem;line-height:1.5;}
#wp-grid{display:flex;flex-direction:column;gap:5px;align-items:center;margin-bottom:1rem;}
.w-row{display:flex;gap:5px;}
.w-cell{width:46px;height:46px;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:1.1rem;font-weight:700;text-transform:uppercase;background:var(--surface);transition:all .15s;}
.w-cell.filled{border-color:var(--dim);}
.w-cell.correct{background:#163d16;border-color:var(--green);color:var(--green);box-shadow:0 0 8px rgba(0,229,160,.3);}
.w-cell.present{background:#3d2d00;border-color:var(--yellow);color:var(--yellow);}
.w-cell.absent{background:#111;border-color:#222;color:#444;}
@keyframes wflip{0%{transform:scaleY(1)}50%{transform:scaleY(0)}100%{transform:scaleY(1)}}
.w-cell.flip{animation:wflip .4s ease;}
@keyframes wshake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
.w-row.shake{animation:wshake .3s ease;}
#wp-input-row{display:flex;gap:.5rem;justify-content:center;margin-bottom:.8rem;}
#wp-input{font-family:'Share Tech Mono',monospace;font-size:.95rem;background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:.5rem .9rem;text-transform:uppercase;width:170px;letter-spacing:.18em;outline:none;}
#wp-input:focus{border-color:var(--accent);}
#wp-keyboard{display:flex;flex-direction:column;gap:4px;align-items:center;}
.kb-row{display:flex;gap:3px;}
.kb-key{font-family:'Share Tech Mono',monospace;font-size:.7rem;padding:.38rem .45rem;min-width:28px;background:var(--surface2);border:1px solid var(--border);color:var(--text);cursor:pointer;transition:all .15s;text-transform:uppercase;}
.kb-key:hover{border-color:var(--accent);color:var(--accent);}
.kb-key.correct{background:#163d16;border-color:var(--green);color:var(--green);}
.kb-key.present{background:#3d2d00;border-color:var(--yellow);color:var(--yellow);}
.kb-key.absent{background:#0d0d0d;border-color:#1a1a1a;color:#333;}
.kb-key.wide{min-width:50px;}

/* ══════════════════════════════════════════════════
   QUIZ
══════════════════════════════════════════════════ */
.qz-hud{display:flex;justify-content:space-between;font-family:'Share Tech Mono',monospace;font-size:.75rem;color:var(--dim);margin-bottom:.7rem;padding-bottom:.6rem;border-bottom:1px solid var(--border);}
.qz-hud span{color:var(--accent);}
.qz-prog{height:4px;background:var(--surface2);margin-bottom:1.2rem;}
.qz-prog-bar{height:100%;background:var(--accent);transition:width .4s;box-shadow:0 0 6px var(--accent);}
#qz-cat{font-family:'Share Tech Mono',monospace;font-size:.68rem;color:var(--accent2);margin-bottom:.4rem;letter-spacing:.1em;}
#qz-q{font-size:1.5rem;font-weight:600;line-height:1.6;margin-bottom:1.2rem;padding:1.1rem 1.2rem;background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--accent);color:var(--text);}
.qz-opts{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-bottom:.8rem;}
@media(max-width:480px){.qz-opts{grid-template-columns:1fr;}}
.qz-opt{padding:.9rem 1rem;background:var(--surface);border:1px solid var(--border);color:var(--text);cursor:pointer;font-family:'Exo 2',sans-serif;font-size:1.05rem;text-align:left;transition:all .16s;line-height:1.45;}
.qz-opt:hover:not(:disabled){border-color:var(--accent);background:var(--surface2);color:var(--accent);}
.qz-opt.correct{background:rgba(0,229,160,.1);border-color:var(--green);color:var(--green);}
.qz-opt.wrong{background:rgba(255,61,90,.1);border-color:var(--red);color:var(--red);}
.qz-opt:disabled{cursor:default;}
#qz-exp{font-family:'Share Tech Mono',monospace;font-size:.9rem;padding:.65rem .9rem;border:1px dashed var(--border);color:var(--dim);line-height:1.5;display:none;margin-bottom:.7rem;}
.qz-score-card{text-align:center;padding:2rem;background:var(--surface);border:1px solid var(--border);}
.qz-big{font-family:'Orbitron',monospace;font-size:3.2rem;font-weight:900;color:var(--accent);text-shadow:0 0 30px rgba(0,200,240,.5);}

/* ══════════════════════════════════════════════════
   CONNECT 4
══════════════════════════════════════════════════ */
.c4-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:.8rem;flex-wrap:wrap;gap:.5rem;}
.c4-plabel{font-family:'Share Tech Mono',monospace;font-size:.78rem;padding:.35rem .9rem;border:1px solid var(--border);transition:all .2s;}
.c4-plabel.p1{color:var(--p1);}
.c4-plabel.p2{color:var(--p2);}
.c4-plabel.active{border-width:2px;box-shadow:0 0 12px currentColor;}
#c4-turn{font-family:'Share Tech Mono',monospace;font-size:.78rem;color:var(--dim);text-align:center;margin-bottom:.6rem;}
#c4-col-btns{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-bottom:2px;}
.c4-cbtn{background:transparent;border:1px solid transparent;color:var(--dim);font-size:.9rem;cursor:pointer;padding:.2rem;transition:all .14s;}
.c4-cbtn:hover{color:var(--accent);border-color:var(--accent);}
#c4-board{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;background:var(--surface);padding:8px;border:1px solid var(--border);margin-bottom:.8rem;}
.c4-cell{width:100%;aspect-ratio:1;border-radius:50%;background:var(--surface2);border:2px solid var(--border);transition:all .15s;}
.c4-cell.p1{background:var(--p1);border-color:var(--p1);box-shadow:0 0 8px var(--p1);}
.c4-cell.p2{background:var(--p2);border-color:var(--p2);box-shadow:0 0 8px var(--p2);}
@keyframes cpulse{from{opacity:1}to{opacity:.35}}
.c4-cell.win{animation:cpulse .55s infinite alternate;}
#c4-qpanel{background:var(--surface);border:1px solid var(--accent);padding:1rem 1.2rem;margin-bottom:.8rem;display:none;box-shadow:0 0 20px rgba(0,200,240,.08);}
#c4-qpanel h3{font-family:'Orbitron',monospace;font-size:.72rem;color:var(--accent2);margin-bottom:.6rem;letter-spacing:.1em;}
#c4-qtext{font-size:1.45rem;line-height:1.55;margin-bottom:.9rem;color:var(--text);}
.c4-opts{display:grid;grid-template-columns:1fr 1fr;gap:.45rem;}
.c4-opt{padding:.7rem .9rem;background:var(--surface2);border:1px solid var(--border);color:var(--text);cursor:pointer;font-size:1rem;text-align:left;transition:all .14s;}
.c4-opt:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
.c4-opt.correct{background:rgba(0,229,160,.1);border-color:var(--green);color:var(--green);}
.c4-opt.wrong{background:rgba(255,61,90,.1);border-color:var(--red);color:var(--red);}

/* ══════════════════════════════════════════════════
   HANGMAN
══════════════════════════════════════════════════ */
.hm-layout{display:grid;grid-template-columns:150px 1fr;gap:1.5rem;align-items:start;}
@media(max-width:480px){.hm-layout{grid-template-columns:1fr;}}
#hm-svg{width:150px;height:170px;}
.hm-part{opacity:0;transition:opacity .3s;}
.hm-part.show{opacity:1;}
#hm-cat{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--accent2);letter-spacing:.1em;margin-bottom:.3rem;}
#hm-hint{font-family:'Share Tech Mono',monospace;font-size:.75rem;color:var(--dim);margin-bottom:.9rem;line-height:1.45;}
#hm-word{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:1rem;}
.hm-l{width:26px;height:32px;border-bottom:2px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;text-transform:uppercase;color:var(--text);}
.hm-l.sp{border-bottom-color:transparent;width:12px;}
#hm-lives{font-family:'Share Tech Mono',monospace;font-size:.9rem;color:var(--dim);margin-bottom:.8rem;}
#hm-guessed{font-family:'Share Tech Mono',monospace;font-size:.72rem;color:var(--dim);margin-bottom:.8rem;min-height:1.4rem;}
#hm-keyboard{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:.8rem;}
.hm-key{font-family:'Share Tech Mono',monospace;font-size:.72rem;width:30px;height:30px;background:var(--surface2);border:1px solid var(--border);color:var(--text);cursor:pointer;transition:all .14s;display:flex;align-items:center;justify-content:center;text-transform:uppercase;}
.hm-key:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
.hm-key:disabled{opacity:.2;cursor:default;}
.hm-key.hit{background:rgba(0,229,160,.15);border-color:var(--green);color:var(--green);}
.hm-key.miss{background:rgba(255,61,90,.1);border-color:var(--red);color:var(--red);}

/* ══════════════════════════════════════════════════
   NETWORK CHALLENGE
══════════════════════════════════════════════════ */
#nc-screen{align-items:center;justify-content:center;padding:2rem 1rem;}
.nc-card{max-width:500px;width:100%;background:var(--surface);border:1px solid var(--border);padding:2rem 1.8rem;position:relative;}
.nc-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--accent),var(--accent2));}
.nc-hud{background:var(--surface);border-bottom:1px solid var(--border);padding:.65rem 1.4rem;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:.8rem;flex-shrink:0;}
.nc-hud-l{font-family:'Orbitron',monospace;font-size:.75rem;color:var(--accent);}
