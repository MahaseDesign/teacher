  const topic   = document.getElementById('pol-topic')?.value.trim()||'GCSE Computer Science Revision';
  const notes   = document.getElementById('pol-notes')?.value.trim()||'';
  const names   = [...new Set(tLeaderboard.map(e=>e.name))];
  const avg     = Math.round(tLeaderboard.reduce((s,e)=>s+(e.totalScore||0),0)/tLeaderboard.length);
  const esc = c => { const s=String(c==null?'':c); return (s.includes(',')||s.includes('"')||s.includes('\n')) ? '"'+s.replace(/"/g,'""')+'"' : s; };
  const row = (...cols) => cols.map(esc).join(',');
  const lines = [
    row('CORBY BUSINESS ACADEMY — COMPUTER SCIENCE DEPARTMENT'),
    row('Keyword Arena — Proof of Learning'),
    '',
    row('Teacher:',teacher,'Class:',cls,'Date:',date),
    row('Topic:',topic),
    notes ? row('Notes:',notes) : null,
    '',
    row('SUMMARY'),
    row('Students:',names.length,'Average Score:',avg,'Top Score:',tLeaderboard[0]?.totalScore||0),
    row('Quiz Plays:',tLeaderboard.filter(e=>e.quizScore!=null).length,
        'Network Plays:',tLeaderboard.filter(e=>e.networkScore!=null).length,
        'Python:',tLeaderboard.filter(e=>e.pythonScore!=null).length),
    '',
    row('LEADERBOARD'),
    row('Rank','Name','Class','Total Score','Quiz /10','Network','Python','Wordle','Hangman','C4','Last Game','Date'),
    ...tLeaderboard.map((e,i)=>row(i+1,e.name,e.cls,e.totalScore||0,
      e.quizScore!=null?e.quizScore:'', e.networkScore!=null?e.networkScore:'',
      e.pythonScore!=null?e.pythonScore:'',
      e.wordleWon?'YES':'NO', e.hangmanWon?'YES':'NO',
      e.c4Win||'', e.game||'', e.date||'')),
    '',
    row('PYTHON TOPICS'),
    row('Topic','Students','% Class'),
    ...T_PY_TOPICS.map(t=>{
      const n=tLeaderboard.filter(e=>e.pythonTopics&&e.pythonTopics.includes(t)).length;
      return row(t,n,Math.round((n/(names.length||1))*100)+'%');
    })
  ].filter(l=>l!==null).join('\n');
  const blob = new Blob(['\uFEFF'+lines],{type:'text/csv;charset=utf-8;'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'CBA_PoL_'+new Date().toISOString().slice(0,10)+'.csv';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

document.addEventListener('DOMContentLoaded', function() {
  if(store.get('cba_theme')==='light'){
    document.body.classList.add('light');
    const b=document.getElementById('theme-btn'); if(b) b.textContent='\u{1F319} DARK';
  }
  updateGsUiTeacher(); teacherInit();
});

</script>
